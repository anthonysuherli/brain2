# br8n backend — copy to .env and fill in real values.
#
# br8n ships in two tiers from one engine. Pick ONE block below.
# Backend selection: BR8N_BACKEND ("local" | "cloud"); if unset, br8n uses
# cloud iff Supabase creds are present, else local.

# ─────────────────────────────────────────────────────────────────────────────
# FREE / LOCAL TIER
#   On-device SQLite (+ sqlite-vec). No account, no Supabase, no BR8N_API_KEY.
#   Bring your own keys. The API server binds to 127.0.0.1 and skips auth.
# ─────────────────────────────────────────────────────────────────────────────
BR8N_BACKEND=local
OPENAI_API_KEY=sk-...                 # required — embeddings
# TAVILY_API_KEY=tvly-...             # optional — gap-fill explore (web research)
# BR8N_DB_PATH=~/.br8n/brain.db   # optional — local DB location (this is the default)

# ─────────────────────────────────────────────────────────────────────────────
# PAID / CLOUD TIER
#   Today's Supabase backend (GoTrue + pgvector + RLS). Managed multi-tenant.
#   Set BR8N_BACKEND=cloud (or just provide the Supabase creds) and uncomment.
# ─────────────────────────────────────────────────────────────────────────────
# BR8N_BACKEND=cloud
#
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-jwt-secret
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
#
# # Vercel AI Gateway (explore pipeline)
# AI_GATEWAY_API_KEY=your-gateway-key
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
#
# # Tavily (gap-fill explore)
# TAVILY_API_KEY=tvly-...
#
# # MCP server auth: the VS Code extension and Claude Code both use this account
# DVG_MCP_USER_EMAIL=you@example.com
# DVG_MCP_USER_PASSWORD=your-supabase-password
#
# # br8n API key — sent by the VS Code extension in Authorization: Bearer
# # (cloud tier only; the local tier requires no key)
# BR8N_API_KEY=br8n_...
#
# CORS_ORIGINS=["http://localhost:3000","vscode-webview://*"]
